{"type": "excalidraw", "version": 2, "source": "https://excalidraw.com", "elements": [{"type": "rectangle", "version": 1, "versionNonce": 10000, "isDeleted": false, "id": "why_bg", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 40, "angle": 0, "x": 40, "y": 0, "strokeColor": "#f59e0b", "backgroundColor": "#fff3bf", "width": 720, "height": 302, "seed": 19000, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"type": "text", "version": 1, "versionNonce": 10001, "isDeleted": false, "id": "why_title", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "x": 60, "y": 20, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "width": 600, "height": 36, "seed": 17001, "groupIds": [], "frameId": null, "roundness": null, "boundElements": null, "updated": 1, "link": null, "locked": false, "fontSize": 24, "fontFamily": 1, "text": "Why this feature?", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "Why this feature?", "lineHeight": 1.25}, {"type": "text", "version": 1, "versionNonce": 10010, "isDeleted": false, "id": "why_b0", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "x": 70, "y": 68, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "width": 680, "height": 20, "seed": 17010, "groupIds": [], "frameId": null, "roundness": null, "boundElements": null, "updated": 1, "link": null, "locked": false, "fontSize": 14, "fontFamily": 1, "text": "\u2022  Telnyx launching WhatsApp Business \u2014 own product, imminent GA", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "\u2022  Telnyx launching WhatsApp Business \u2014 own product, imminent GA", "lineHeight": 1.25}, {"type": "text", "version": 1, "versionNonce": 10011, "isDeleted": false, "id": "why_b1", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "x": 70, "y": 92, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "width": 680, "height": 20, "seed": 17011, "groupIds": [], "frameId": null, "roundness": null, "boundElements": null, "updated": 1, "link": null, "locked": false, "fontSize": 14, "fontFamily": 1, "text": "\u2022  LATAM team just ramped \u2014 first PT-speaking SDRs hired last month", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "\u2022  LATAM team just ramped \u2014 first PT-speaking SDRs hired last month", "lineHeight": 1.25}, {"type": "text", "version": 1, "versionNonce": 10012, "isDeleted": false, "id": "why_b2", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "x": 70, "y": 116, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "width": 680, "height": 20, "seed": 17012, "groupIds": [], "frameId": null, "roundness": null, "boundElements": null, "updated": 1, "link": null, "locked": false, "fontSize": 14, "fontFamily": 1, "text": "\u2022  Quinn has zero WhatsApp coverage today", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "\u2022  Quinn has zero WhatsApp coverage today", "lineHeight": 1.25}, {"type": "text", "version": 1, "versionNonce": 10013, "isDeleted": false, "id": "why_b3", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "x": 70, "y": 140, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "width": 680, "height": 20, "seed": 17013, "groupIds": [], "frameId": null, "roundness": null, "boundElements": null, "updated": 1, "link": null, "locked": false, "fontSize": 14, "fontFamily": 1, "text": "\u2022  The dogfood angle: extend Quinn with Telnyx's own soon-launching product", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "\u2022  The dogfood angle: extend Quinn with Telnyx's own soon-launching product", "lineHeight": 1.25}, {"type": "text", "version": 1, "versionNonce": 10014, "isDeleted": false, "id": "why_b4", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "x": 70, "y": 164, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "width": 680, "height": 20, "seed": 17014, "groupIds": [], "frameId": null, "roundness": null, "boundElements": null, "updated": 1, "link": null, "locked": false, "fontSize": 14, "fontFamily": 1, "text": "\u2022  ROI: ~$86K/yr pessimistic floor \u00b7 ~$420K/yr conservative \u00b7 ~$5\u201319M/yr post-GA", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "\u2022  ROI: ~$86K/yr pessimistic floor \u00b7 ~$420K/yr conservative \u00b7 ~$5\u201319M/yr post-GA", "lineHeight": 1.25}, {"type": "text", "version": 1, "versionNonce": 10015, "isDeleted": false, "id": "why_b5", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "x": 70, "y": 188, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "width": 680, "height": 20, "seed": 17015, "groupIds": [], "frameId": null, "roundness": null, "boundElements": null, "updated": 1, "link": null, "locked": false, "fontSize": 14, "fontFamily": 1, "text": "\u2022  Math holds even if inputs wrong by 2-3x \u2014 pessimistic case still pays back the build inside a quarter", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "\u2022  Math holds even if inputs wrong by 2-3x \u2014 pessimistic case still pays back the build inside a quarter", "lineHeight": 1.25}, {"type": "text", "version": 1, "versionNonce": 10016, "isDeleted": false, "id": "why_b6", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "angle": 0, "x": 70, "y": 212, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "width": 680, "height": 20, "s